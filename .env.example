# ──────────────────────────────────────────────────────────
# API Gateway — Environment Variables
# Copy to .env and fill in values before running
# ──────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
GATEWAY_BASE_URL=http://localhost:3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (Gateway authentication)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=1h
JWT_ALGORITHM=HS256

# Admin JWT (separate secret for admin dashboard)
ADMIN_JWT_SECRET=change-me-admin-secret-also-at-least-32-chars
ADMIN_JWT_EXPIRES_IN=8h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Rate Limiting (sliding window)
# Per-IP limits (unauthenticated)
RL_IP_WINDOW_MS=60000
RL_IP_MAX_REQUESTS=60

# Per-user limits (authenticated users)
RL_USER_WINDOW_MS=60000
RL_USER_MAX_REQUESTS=300

# Per-API-key limits
RL_APIKEY_WINDOW_MS=60000
RL_APIKEY_MAX_REQUESTS=600

# Circuit Breaker defaults
CB_FAILURE_THRESHOLD=5
CB_SUCCESS_THRESHOLD=2
CB_TIMEOUT_MS=30000
CB_VOLUME_THRESHOLD=10

# Downstream Services
SERVICE_A_URL=http://localhost:3001
SERVICE_B_URL=http://localhost:3002

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
